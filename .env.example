# Environment: development | production
NODE_ENV=development

# Server Configuration
PORT=3000

# ============================================================
# DATABASE - LOCAL DEVELOPMENT
# Gunakan ini saat menjalankan server di lokal
# ============================================================
DB_HOST=localhost
DB_USER=postgres
DB_PASSWORD=your_local_password
DB_NAME=sipangan
DB_PORT=5432

# ============================================================
# DATABASE - PRODUCTION (Supabase)
# Isi DATABASE_URL ini di Vercel Environment Variables
# Jika DATABASE_URL ada, maka DB_HOST/USER/etc di atas diabaikan
# Ambil dari: Supabase → Project → Settings → Database → URI
# Pilih "Transaction" mode (port 6543) untuk Vercel (serverless)
# Format: postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres
# ============================================================
DATABASE_URL=postgresql://postgres.xxxx:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres

# CORS - Comma-separated list of allowed origins
# Production: isi dengan domain frontend yang sudah di-deploy
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# AI Service Configuration (FastAPI)
FASTAPI_URL=http://localhost:8000

# Redis Configuration (Optional for caching)
REDIS_URL=redis://localhost:6379
